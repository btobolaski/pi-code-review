{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "noEmit": true,
    "paths": {
      "preact/jsx-runtime": ["./node_modules/preact/jsx-runtime"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../extension/src/types.ts", "../extension/src/format.ts"]
}
